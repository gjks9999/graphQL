{
  "name": "graphql-firebase-backend",
  "version": "1.0.0",
  "description": "Professional TypeScript GraphQL backend with Firebase integration",
  "main": "dist/index.ts",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "test": "jest"
  },
  "keywords": [
    "graphql",
    "typescript",
    "firebase",
    "apollo-server"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@graphql-hive/cli": "^0.60.0",
    "apollo-server-express": "^3.11.1",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "firebase": "^9.22.1",
    "firebase-admin": "^11.10.0",
    "graphql": "^16.8.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^18.16.9",
    "@typescript-eslint/eslint-plugin": "^5.59.9",
    "@typescript-eslint/parser": "^5.59.9",
    "eslint": "^8.41.0",
    "jest": "^29.5.0",
    "nodemon": "^2.0.22",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.4"
  }
}
